{
  "name": "@nanostores/router",
  "version": "1.0.0",
  "description": "A tiny (712 bytes) router for Nano Stores state manager",
  "keywords": [
    "nano",
    "preact",
    "react",
    "router",
    "store",
    "svelte",
    "vue"
  ],
  "license": "MIT",
  "author": "Andrey Sitnik <andrey@sitnik.es>",
  "repository": "nanostores/router",
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/ai"
    }
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./index.d.ts",
  "exports": {
    ".": "./index.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test:lint": "oxlint",
    "test:coverage": "pnpm bnt --coverage 100",
    "test:types": "check-dts",
    "test:size": "size-limit",
    "test": "pnpm run /^test:/"
  },
  "devDependencies": {
    "@logux/oxc-configs": "^0.4.0",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.0.1",
    "actions-up": "^1.14.3",
    "better-node-test": "^0.8.4",
    "check-dts": "^1.0.0",
    "jsdom": "^29.1.1",
    "nanostores": "^1.3.0",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "size-limit": "^12.1.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "nanostores": "^0.9.0 || ^0.10.0 || ^0.11.0 || ^1.0.0"
  },
  "size-limit": [
    {
      "name": "Router",
      "import": {
        "./index.js": "{ createRouter }"
      },
      "limit": "712 B"
    }
  ],
  "engines": {
    "node": "^20.0.0 || >=22.0.0"
  },
  "clean-publish": {
    "cleanDocs": true
  }
}
